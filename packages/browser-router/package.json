    "prepare-regress": "node ./dist/js/src/__tests__/regress-browser-router",
    "test": "jest",
    "prod": "npm run build && webpack --config ./dist/js/webpack-prod.conf.js"
  },
  "devDependencies": {
    "@dwfe/utils-node": "^2.0.2",
    "@types/jest": "26",
    "@types/node": "12",
    "jest": "26.6.0",
    "jest-html-reporters": "2.1.2",
    "rimraf": "3",
    "ts-jest": "26",
    "typescript": "4",
    "webpack": "4.44.2",
    "webpack-cli": "3"
  },
  "dependencies": {
    "@do-while-for-each/path-resolver": "^2.0.2",
    "history": "5.0.0"
  }
}
